---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout title="Case File 000">
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-serif mb-6">
      Case File 000
    </h2>

    <p class="font-serif leading-relaxed mb-6">
      You have been assigned preliminary review of a maritime entry anomaly.
    </p>

    <a
      href="/case-000"
      class="bg-slate-700 text-white px-4 py-2 text-sm font-mono uppercase tracking-wide hover:bg-slate-800 transition"
    >
      Begin Review
    </a>
  </main>
</BaseLayout>
